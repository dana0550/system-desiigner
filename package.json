{
  "name": "sdx-cli",
  "version": "0.2.1",
  "description": "System Design Intelligence CLI",
  "type": "commonjs",
  "bin": {
    "sdx": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "oclif": {
    "bin": "sdx",
    "dirname": "sdx",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@oclif/core": "^4.10.3",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.8.0",
    "globby": "^16.2.0",
    "semver": "^7.7.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
